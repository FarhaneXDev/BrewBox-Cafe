# ============================================
# 📋 TEMPLATE DE CONFIGURATION LOCALE
# ⚠️ Copie ce fichier en .env.local et remplis tes propres valeurs
# NE JAMAIS COMMITER .env.local SUR GIT
# ============================================

# NextAuth Configuration
NEXTAUTH_SECRET="your-super-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/brewbox_db?schema=public"

# ============================================
# 🔑 ADMIN CREDENTIALS FOR SEEDS
# ============================================
# Utilisé par prisma/seed-admin.js pour créer les comptes admin initiaux
# Change ces valeurs avec des mots de passe forts!

# Admin Principal
# Email: admin@brewbox.com
# Définis ton mot de passe ici
ADMIN_PASSWORD="ChooseAStrongPassword123!"

# Modérateur
# Email: moderateur@brewbox.com
# Définis ton mot de passe ici
MODERATOR_PASSWORD="ChooseAnotherStrongPassword456!"
